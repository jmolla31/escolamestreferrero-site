# Variables de entorno – copiar a .env y rellenar los valores

# URL del proxy OAuth para Decap CMS (ver docs/decap-oauth-setup.md)
PUBLIC_CMS_OAUTH_PROXY=https://your-oauth-proxy.example.com

# Cloudflare Pages (solo necesario para despliegue local con wrangler)
# CLOUDFLARE_API_TOKEN=
# CLOUDFLARE_ACCOUNT_ID=
