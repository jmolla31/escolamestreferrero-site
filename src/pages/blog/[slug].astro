---
import BlogPostPage from '../../components/pages/BlogPostPage.astro';
import { getCollection } from 'astro:content';
import { parseContentPath } from '../../i18n/utils';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts
    .filter(p => !p.data.draft)
    .map(post => {
      const { lang, slug } = parseContentPath(post.id);
      return {
        params: { slug },
        props: { postId: post.id, lang },
      };
    });
}

const { postId, lang } = Astro.props;
---
<BlogPostPage {postId} {lang} />
