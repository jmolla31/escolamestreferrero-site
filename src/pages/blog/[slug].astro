---
import BlogPostPage from '../../components/pages/BlogPostPage.astro';
import { getCollection } from 'astro:content';
import { parseContentPath } from '../../i18n/utils';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts
    .filter(p => parseContentPath(p.id).lang === 'ca' && !p.data.draft)
    .map(post => ({
      params: { slug: parseContentPath(post.id).slug },
      props: { post, lang: 'ca' as const },
    }));
}

const { post, lang } = Astro.props;
---
<BlogPostPage {post} {lang} />
