---
import CourseDetailPage from '../../../components/pages/CourseDetailPage.astro';
import { getCollection } from 'astro:content';
import { parseContentPath } from '../../../i18n/utils';

export async function getStaticPaths() {
  const courses = await getCollection('cursos');
  return courses
    .filter(c => parseContentPath(c.id).lang === 'es')
    .map(course => ({
      params: { slug: parseContentPath(course.id).slug },
      props: { courseId: course.id, lang: 'es' as const },
    }));
}

const { courseId, lang } = Astro.props;
---
<CourseDetailPage {courseId} {lang} />
