---
import EventDetailPage from '../../../components/pages/EventDetailPage.astro';
import { getCollection } from 'astro:content';
import { parseContentPath } from '../../../i18n/utils';

export async function getStaticPaths() {
  const events = await getCollection('eventos');
  return events
    .filter(event => parseContentPath(event.id).lang === 'es')
    .map(event => ({
      params: { slug: parseContentPath(event.id).slug },
      props: { eventId: event.id, lang: 'es' as const },
    }));
}

const { eventId, lang } = Astro.props;
---

<EventDetailPage {eventId} {lang} />