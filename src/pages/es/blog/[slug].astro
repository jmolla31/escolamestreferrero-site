---
import BlogPostPage from '../../../components/pages/BlogPostPage.astro';
import { getCollection } from 'astro:content';
import { parseContentPath } from '../../../i18n/utils';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts
    .filter(p => parseContentPath(p.id).lang === 'es' && !p.data.draft)
    .map(post => ({
      params: { slug: parseContentPath(post.id).slug },
      props: { postId: post.id, lang: 'es' as const },
    }));
}

const { postId, lang } = Astro.props;
---
<BlogPostPage {postId} {lang} />
