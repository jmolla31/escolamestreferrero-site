---
import { useTranslations, getAlternateLangUrl } from '../i18n/utils';
import type { Lang } from '../i18n/ui';
import siteConfig from '../data/general.json';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const alternateLangUrl = getAlternateLangUrl(Astro.url);
const base = lang === 'es' ? '/es' : '';

const navLinks = [
  { key: 'nav.home' as const, href: `${base}/` },
  { key: 'nav.about' as const, href: `${base}/sobre-nosaltres/` },
  { key: 'nav.courses' as const, href: `${base}/cursos/` },
  { key: 'nav.teachers' as const, href: `${base}/professors/` },
  { key: 'nav.events' as const, href: `${base}/esdeveniments/` },
  { key: 'nav.blog' as const, href: `${base}/blog/` },
  { key: 'nav.contact' as const, href: `${base}/contacte/` },
];
---

<header class="site-header" role="banner">
  <div class="container header-inner">
    <!-- Logo / Nombre -->
    <a href={`${base}/`} class="site-logo" aria-label={siteConfig.schoolName}>
      <!-- Reemplaza con tu logo SVG o imagen -->
      <span class="site-logo__text">{siteConfig.schoolName}</span>
    </a>

    <!-- Navegación principal (desktop) -->
    <button
      type="button"
      class="header-menu-toggle"
      aria-label={lang === 'ca' ? 'Obrir menú' : 'Abrir menú'}
      aria-expanded="false"
      aria-controls="main-navigation"
    >
      <span class="header-menu-toggle__icon"></span>
    </button>

    <nav class="main-nav" id="main-navigation" aria-label={lang === 'ca' ? 'Navegació principal' : 'Navegación principal'}>
      <ul role="list">
        {navLinks.map(({ key, href }) => {
          const isHome = href === `${base}/`;
          const isActive = isHome
            ? Astro.url.pathname === href || Astro.url.pathname === href.slice(0, -1)
            : Astro.url.pathname.startsWith(href);
          return (
            <li>
              <a
                href={href}
                class:list={['main-nav__link', { 'is-active': isActive }]}
                aria-current={isActive ? 'page' : undefined}
              >
                {t(key)}
              </a>
            </li>
          );
        })}
      </ul>
      <div class="main-nav__actions">
        <a href={alternateLangUrl} class="lang-switch" hreflang={lang === 'ca' ? 'es' : 'ca'}>
          {t('lang.switch')}
        </a>
      </div>
    </nav>

    <div class="header-actions">
      <!-- Selector de idioma -->
      <a href={alternateLangUrl} class="lang-switch" hreflang={lang === 'ca' ? 'es' : 'ca'}>
        {t('lang.switch')}
      </a>
    </div>
  </div>
</header>


<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background-color: var(--color-brand);
    border-bottom: 1px solid var(--color-border-dark);
    box-shadow: 0 2px 16px rgba(0, 0, 0, 0.25);
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    height: 4rem;
  }

  .site-logo {
    text-decoration: none;
    flex-shrink: 0;
  }

  @media (min-width: 993px) {
    .site-logo {
      margin-inline-start: -2rem;
    }
  }

  .site-logo__text {
    font-family: 'Weissenhof Grotesk', system-ui, sans-serif;
    font-size: 1.15rem;
    font-weight: 700;
    color: #ffffff;
    letter-spacing: -0.02em;
  }

  .main-nav {
    display: block;
  }

  .main-nav ul {
    display: flex;
    gap: 0.25rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .main-nav__link {
    display: block;
    padding: 0.4rem 0.75rem;
    font-size: 0.88rem;
    font-weight: 500;
    letter-spacing: 0.01em;
    color: rgba(255, 255, 255, 0.8);
    text-decoration: none;
    border-radius: 0.25rem;
    transition: color 0.15s, background-color 0.15s;
  }

  .main-nav__link:hover,
  .main-nav__link.is-active {
    color: var(--color-accent);
    background-color: rgba(255, 255, 255, 0.07);
  }

  .main-nav__actions {
    display: none;
    margin-top: 2rem;
    padding-top: 1rem;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
  }

  .header-menu-toggle {
    display: none;
    width: 2.5rem;
    height: 2.5rem;
    padding: 0;
    border: none;
    background: transparent;
    cursor: pointer;
    position: relative;
    z-index: 101;
  }

  .header-menu-toggle__icon {
    display: block;
    width: 1.5rem;
    height: 2px;
    background-color: #fff;
    position: absolute;
    left: 0.5rem;
    top: 1.25rem;
    transition: transform 0.2s, top 0.2s;
  }

  .header-menu-toggle__icon::before,
  .header-menu-toggle__icon::after {
    content: '';
    position: absolute;
    width: 1.5rem;
    height: 2px;
    background-color: #fff;
    left: 0;
    transition: transform 0.2s, top 0.2s;
  }

  .header-menu-toggle__icon::before {
    top: -6px;
  }

  .header-menu-toggle__icon::after {
    top: 6px;
  }

  .header-menu-toggle[aria-expanded='true'] .header-menu-toggle__icon {
    transform: rotate(135deg);
    top: 1.25rem;
  }

  .header-menu-toggle[aria-expanded='true'] .header-menu-toggle__icon::before {
    transform: rotate(-90deg);
    top: 0;
  }

  .header-menu-toggle[aria-expanded='true'] .header-menu-toggle__icon::after {
    transform: rotate(90deg);
    top: 0;
  }

  .header-actions {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  @media (max-width: 992px) {
    .header-actions {
      display: none;
    }
    .header-menu-toggle {
      display: block;
    }


  .lang-switch {
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 0.3rem 0.8rem;
    border: 1.5px solid var(--color-accent);
    border-radius: 99px;
    text-decoration: none;
    color: var(--color-accent);
    transition: background-color 0.15s, color 0.15s;
  }

  .lang-switch:hover {
    background-color: var(--color-accent);
    color: var(--color-brand);
  }

  @media (max-width: 992px) {
    .header-menu-toggle {
      display: block;
    }

    .main-nav {
      position: fixed;
      top: 0;
      inset-inline-end: 0;
      bottom: 0;
      width: 280px;
      background-color: var(--color-brand);
      padding: 5rem 1.5rem 2rem;
      transform: translateX(100%);
      transition: transform 0.3s ease;
      z-index: 100;
      box-shadow: -4px 0 16px rgba(0, 0, 0, 0.2);
    }

    .main-nav.is-open {
      transform: translateX(0);
    }

    .main-nav ul {
      flex-direction: column;
      gap: 1rem;
    }

    .main-nav__actions {
      display: block;
    }

    .main-nav__link {
      font-size: 1.1rem;
      padding: 0.75rem 1rem;
    }
  }


</style>

<script>
  function setupHeader() {
    const toggle = document.querySelector('.header-menu-toggle');
    const nav = document.querySelector('.main-nav');

    if (!toggle || !nav) return;

    toggle.addEventListener('click', () => {
      const isOpen = toggle.getAttribute('aria-expanded') === 'true';
      toggle.setAttribute('aria-expanded', (!isOpen).toString());
      nav.classList.toggle('is-open');
    });

    // Close menu when clicking a link
    const links = nav.querySelectorAll('.main-nav__link');
    links.forEach(link => {
      link.addEventListener('click', () => {
        toggle.setAttribute('aria-expanded', 'false');
        nav.classList.remove('is-open');
      });
    });
  }

  setupHeader();
  document.addEventListener('astro:after-swap', setupHeader);
</script>
