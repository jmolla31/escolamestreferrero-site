---
interface Props {
  name: string;
  specialty: string;
  photo?: string;
  bio?: string;
}

const { name, specialty, photo, bio } = Astro.props;
---

<article class="teacher-card">
  <div class="teacher-card__photo-wrap">
    {photo
      ? <img src={photo} alt={name} class="img-cover" loading="lazy" />
      : <div class="teacher-card__initials" aria-hidden="true">
          {name.split(' ').slice(0, 2).map(w => w[0]).join('')}
        </div>
    }
  </div>
  <div class="teacher-card__body">
    <p class="teacher-card__specialty">{specialty}</p>
    <h3 class="teacher-card__name">{name}</h3>
    {bio && <p class="teacher-card__bio line-clamp-3">{bio}</p>}
  </div>
</article>

<style>
  .teacher-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 1rem;
  }

  .teacher-card__photo-wrap {
    width: 140px;
    height: 140px;
    border-radius: 50%;
    overflow: hidden;
    background-color: var(--color-surface-alt);
    flex-shrink: 0;
    border: 3px solid var(--color-border);
  }

  .teacher-card__photo-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .teacher-card__initials {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'Weissenhof Grotesk', system-ui, sans-serif;
    font-size: 2rem;
    font-weight: 700;
    color: var(--color-brand);
    background-color: color-mix(in srgb, var(--color-brand) 10%, transparent);
  }

  .teacher-card__body {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .teacher-card__specialty {
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin: 0;
  }

  .teacher-card__name {
    font-size: 1.1rem;
    margin: 0;
  }

  .teacher-card__bio {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    margin: 0;
  }
</style>
