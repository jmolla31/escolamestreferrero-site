---
import { useTranslations } from '../i18n/utils';
import type { Lang } from '../i18n/ui';

interface Props {
  title: string;
  startDate: Date;
  location: string;
  image?: string;
  ticketUrl?: string;
  slug: string;
  lang: Lang;
}

const { title, startDate, location, image, ticketUrl, slug, lang } = Astro.props;
const t = useTranslations(lang);
const base = lang === 'ca' ? '/ca' : '';
const eventBase = lang === 'ca' ? 'esdeveniments' : 'eventos';

const dateStr = startDate.toLocaleDateString(lang === 'ca' ? 'ca-ES' : 'es-ES', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});
---

<article class="event-card">
  {image && (
    <div class="event-card__image-wrap">
      <img src={image} alt={title} class="img-cover" loading="lazy" />
    </div>
  )}
  <div class="event-card__body">
    <time class="event-card__date" datetime={startDate.toISOString()}>
      {dateStr}
    </time>
    <h3 class="event-card__title">
      <a href={`${base}/${eventBase}/${slug}/`}>{title}</a>
    </h3>
    <p class="event-card__location">
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 0 1-2.827 0l-4.244-4.243a8 8 0 1 1 11.314 0z"/>
        <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 1 1-6 0 3 3 0 0 1 6 0z"/>
      </svg>
      {location}
    </p>
    {ticketUrl && (
      <a href={ticketUrl} class="btn btn--accent event-card__ticket" target="_blank" rel="noopener noreferrer">
        {t('events.tickets')}
      </a>
    )}
  </div>
</article>

<style>
  .event-card {
    display: flex;
    gap: 1.25rem;
    align-items: flex-start;
    padding: 1.25rem;
    border: 1px solid var(--color-border);
    border-radius: 0.75rem;
    background: var(--color-surface);
    transition: box-shadow 0.2s;
  }

  .event-card:hover {
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.08);
  }

  .event-card__image-wrap {
    width: 80px;
    height: 80px;
    border-radius: 0.5rem;
    overflow: hidden;
    flex-shrink: 0;
  }

  .event-card__image-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .event-card__body {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    flex: 1;
    min-width: 0;
  }

  .event-card__date {
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--color-accent);
  }

  .event-card__title {
    font-size: 1rem;
    margin: 0;
  }

  .event-card__title a {
    color: var(--color-text);
    text-decoration: none;
  }

  .event-card__title a:hover {
    color: var(--color-brand);
  }

  .event-card__location {
    display: flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.85rem;
    color: var(--color-text-muted);
    margin: 0;
  }

  .event-card__ticket {
    align-self: flex-start;
    font-size: 0.8rem;
    padding: 0.35em 0.9em;
    margin-top: 0.25rem;
  }
</style>
