---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import TeacherCard from '../../components/TeacherCard.astro';
import EventCard from '../../components/EventCard.astro';
import BlogCard from '../../components/BlogCard.astro';
import { getCollection } from 'astro:content';
import { useTranslations, parseContentPath } from '../../i18n/utils';
import type { Lang } from '../../i18n/ui';
import siteConfig from '../../data/general.json';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const base = lang === 'es' ? '/es' : '';

// Profesores (ordenados)
const allTeachers = await getCollection('profesores');
const teachers = allTeachers
  .filter(p => {
    const { lang: pLang } = parseContentPath(p.id);
    return pLang === lang;
  })
  .sort((a, b) => a.data.order - b.data.order);

// Próximos eventos
const now = new Date();
const allEvents = await getCollection('eventos');
const upcomingEvents = allEvents
  .filter(e => {
    const { lang: eLang } = parseContentPath(e.id);
    return eLang === lang && e.data.startDate >= now;
  })
  .sort((a, b) => a.data.startDate.getTime() - b.data.startDate.getTime())
  .slice(0, 2);

// Últimas noticias
const allPosts = await getCollection('blog');
const latestPosts = allPosts
  .filter(p => {
    const { lang: pLang } = parseContentPath(p.id);
    return pLang === lang && !p.data.draft;
  })
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);

// ── Home hero cards (edit freely to mix blog, pages, events…) ──────────────
const homeCards = [
  {
    image: '/uploads/blog/matricula-oberta.jpg',
    label: { ca: 'Notícies',    es: 'Noticias' },
    title: { ca: 'Matrícula oberta 2026/2027', es: 'Matrícula abierta 2026/2027' },
    href:  { ca: '/blog/matricula-oberta-2026-2027/', es: '/es/blog/matricula-abierta-2026-2027/' },
    cta:   { ca: 'Llegir més →', es: 'Leer más →' },
  },
  {
    image: '/uploads/blog/aules-obertes.jpg',
    label: { ca: 'Notícies',    es: 'Noticias' },
    title: { ca: 'Aules Obertes', es: 'Aulas Abiertas' },
    href:  { ca: '/blog/aules-obertes/', es: '/es/blog/aulas-abiertas/' },
    cta:   { ca: 'Llegir més →', es: 'Leer más →' },
  },
  {
    image: '/uploads/hero/hero-main.jpg',
    label: { ca: "L'escola",    es: 'La escuela' },
    title: { ca: 'La Nostra Escola', es: 'Nuestra Escuela' },
    href:  { ca: '/sobre-nosaltres/', es: '/es/sobre-nosotros/' },
    cta:   { ca: 'Descobrir →', es: 'Descubrir →' },
  },
  {
    image: '/uploads/hero/hero-main.jpg',
    label: { ca: 'Agrupació',   es: 'Agrupación' },
    title: { ca: 'Banda Jove', es: 'Banda Joven' },
    href:  { ca: '/banda-jove/', es: '/es/banda-joven/' },
    cta:   { ca: 'Descobrir →', es: 'Descubrir →' },
  },
];
---

<BaseLayout
  title={lang === 'ca' ? 'Inici' : 'Inicio'}
  description={lang === 'ca'
    ? `Benvingut a ${siteConfig.schoolName}. Descobreix els nostres cursos de música.`
    : `Bienvenido a ${siteConfig.schoolName}. Descubre nuestros cursos de música.`}
  {lang}
>
  <!-- Home hero cards (mixed content) -->
  <section class="news-hero" aria-label={lang === 'ca' ? 'Destacats' : 'Destacados'}>
    <div class="news-hero__grid">
      {homeCards.map(card => (
        <a
          href={card.href[lang]}
          class="news-hero__card"
          style={card.image ? `--card-bg: url('${card.image}')` : ''}
        >
          <div class="news-hero__overlay" aria-hidden="true"></div>
          <div class="news-hero__body">
            <h2 class="news-hero__title">{card.title[lang]}</h2>
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- Profesores -->
  {teachers.length > 0 && (
    <section class="section section--alt">
      <div class="container">
        <SectionHeader title={t('home.teachers.title')} centered />
        <div class="teachers-strip">
          {teachers.map(teacher => {
            const rendered = teacher.rendered;
            return (
              <TeacherCard
                name={teacher.data.name}
                specialty={teacher.data.specialty}
                photo={teacher.data.photo}
              />
            );
          })}
        </div>
        <div class="section-cta">
          <a href={`${base}/${lang === 'ca' ? 'professors' : 'profesores'}/`} class="btn btn--outline">{t('home.teachers.more')}</a>
        </div>
      </div>
    </section>
  )}

  <!-- Próximos eventos -->
  {upcomingEvents.length > 0 && (
    <section class="section">
      <div class="container">
        <SectionHeader title={t('home.events.title')} />
        <div class="events-list">
          {upcomingEvents.map(event => {
            const { slug } = parseContentPath(event.id);
            return (
              <EventCard
                title={event.data.title}
                startDate={event.data.startDate}
                location={event.data.location}
                image={event.data.image}
                ticketUrl={event.data.ticketUrl}
                {slug}
                {lang}
              />
            );
          })}
        </div>
        <div class="section-cta">
          <a href={`${base}/${lang === 'ca' ? 'esdeveniments' : 'eventos'}/`} class="btn btn--outline">{t('home.events.more')}</a>
        </div>
      </div>
    </section>
  )}

  <!-- Últimas noticias -->
  {latestPosts.length > 0 && (
    <section class="section section--alt">
      <div class="container">
        <SectionHeader title={t('home.blog.title')} />
        <div class="cards-grid">
          {latestPosts.map(post => {
            const { slug } = parseContentPath(post.id);
            return (
              <BlogCard
                title={post.data.title}
                excerpt={post.data.excerpt}
                date={post.data.date}
                heroImage={post.data.heroImage}
                {slug}
                {lang}
              />
            );
          })}
        </div>
        <div class="section-cta">
          <a href={`${base}/blog/`} class="btn btn--outline">{t('home.blog.more')}</a>
        </div>
      </div>
    </section>
  )}

  <!-- CTA de contacto -->
  <section class="section section--dark contact-cta">
    <div class="container">
      <h2>{lang === 'ca' ? '¿Vols saber-ne més?' : '¿Quieres saber más?'}</h2>
      <p>{lang === 'ca'
        ? 'Contacta\'ns sense compromís. T\'informarem de tots els cursos i activitats.'
        : 'Contáctanos sin compromiso. Te informaremos de todos los cursos y actividades.'
      }</p>
      <a href={`${base}/${lang === 'ca' ? 'contacte' : 'contacto'}/`} class="btn btn--accent">
        {t('nav.contact')}
      </a>
    </div>
  </section>
</BaseLayout>

<style>
  .teachers-strip {
    display: flex;
    flex-wrap: nowrap;
    gap: 1.5rem;
    overflow-x: auto;
    overflow-y: clip;
    -webkit-overflow-scrolling: touch;
    scroll-snap-type: x proximity;
    padding-bottom: 0.5rem;
    scrollbar-width: thin;
    scrollbar-color: var(--color-border) transparent;
  }

  .teachers-strip::-webkit-scrollbar {
    height: 6px;
  }

  .teachers-strip::-webkit-scrollbar-track {
    background: transparent;
  }

  .teachers-strip::-webkit-scrollbar-thumb {
    background-color: var(--color-border);
    border-radius: 99px;
  }

  .teachers-strip > :global(.teacher-card) {
    flex: 1 0 160px;
    scroll-snap-align: start;
  }

  .events-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .section-cta {
    display: flex;
    justify-content: center;
    margin-top: 2.5rem;
  }

  .contact-cta .container {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 1rem;
  }

  .contact-cta h2 {
    margin: 0;
  }

  .contact-cta p {
    color: rgba(255, 255, 255, 0.75);
    max-width: 52ch;
    margin: 0;
  }

  /* ── News image-button cards ─────────────────────────── */
  .news-hero {
    width: 100%;
  }

  .news-hero__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    grid-template-rows: repeat(2, clamp(220px, 30vw, 360px));
  }

  .news-hero__card {
    position: relative;
    display: flex;
    align-items: flex-end;
    overflow: hidden;
    text-decoration: none;
    background-color: var(--color-brand);
    background-image: var(--card-bg, none);
    background-size: cover;
    background-position: center;
    color: #fff;
    transition: transform 0.35s ease;
  }

  .news-hero__card:hover,
  .news-hero__card:focus-visible {
    z-index: 1;
    transform: scale(1.02);
    outline: 3px solid var(--color-accent, #c6b300);
    outline-offset: -3px;
  }

  .news-hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(14, 18, 53, 0.85) 0%, rgba(14, 18, 53, 0.25) 60%, transparent 100%);
    transition: background 0.35s ease;
  }

  .news-hero__card:hover .news-hero__overlay {
    background: linear-gradient(to top, rgba(14, 18, 53, 0.92) 0%, rgba(14, 18, 53, 0.4) 60%, transparent 100%);
  }

  .news-hero__body {
    position: relative;
    padding: 1.25rem 1.5rem;
  }

  .news-hero__title {
    margin: 0;
    font-size: clamp(1.1rem, 2.5vw, 1.6rem);
    line-height: 1.25;
    font-weight: 700;
    color: #fff;
  }

  @media (max-width: 600px) {
    .news-hero__grid {
      grid-template-columns: 1fr;
      grid-template-rows: repeat(4, clamp(180px, 50vw, 260px));
    }
  }
</style>
