---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import { useTranslations } from '../../i18n/utils';
import type { Lang } from '../../i18n/ui';
import siteConfig from '../../data/general.json';
import ContactForm from '../../components/ContactForm.astro';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<BaseLayout title={t('contact.title')} {lang}>
  <div class="container section">
    <SectionHeader title={t('contact.title')} />

    <div class="contact-layout">
      <!-- Info de contacto -->
      <aside class="contact-info">
        <dl>
          <div class="contact-info__item">
            <dt>{t('contact.phone')}</dt>
            <dd><a href={`tel:${siteConfig.phone.replace(/\s/g, '')}`}>{siteConfig.phone}</a></dd>
          </div>
          <div class="contact-info__item">
            <dt>{t('contact.email')}</dt>
            <dd><a href={`mailto:${siteConfig.email}`}>{siteConfig.email}</a></dd>
          </div>
          <div class="contact-info__item">
            <dt>{t('contact.address')}</dt>
            <dd>{siteConfig.address}</dd>
          </div>
        </dl>
      </aside>

      <ContactForm 
        lang={lang} 
        endpoint="https://script.google.com/macros/s/AKfycbx-azPR5c533TYVx9slk6uvtnVaVbDVrytjGbR5XFZrUMJSfVj_LPpNyK1N4XuMrm8N/exec" 
        section="Contacte"
      />
    </div>
  </div>
</BaseLayout>

<style>
  .contact-layout {
    display: grid;
    gap: 3rem;
    grid-template-columns: 1fr;
  }

  @media (min-width: 700px) {
    .contact-layout {
      grid-template-columns: 1fr 2fr;
      align-items: start;
    }
  }

  .contact-info dl {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    margin: 0;
  }

  .contact-info__item dt {
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 0.2rem;
  }

  .contact-info__item dd {
    margin: 0;
    font-size: 1rem;
    color: var(--color-text);
    line-height: 1.5;
  }

  .contact-info__item a {
    color: var(--color-brand);
    text-decoration: none;
  }

  .contact-info__item a:hover {
    text-decoration: underline;
  }
</style>

