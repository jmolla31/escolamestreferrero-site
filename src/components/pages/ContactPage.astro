---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import { useTranslations } from '../../i18n/utils';
import type { Lang } from '../../i18n/ui';
import siteConfig from '../../data/general.json';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<BaseLayout title={t('contact.title')} {lang}>
  <div class="container section">
    <SectionHeader title={t('contact.title')} />

    <div class="contact-layout">
      <!-- Info de contacto -->
      <aside class="contact-info">
        <dl>
          <div class="contact-info__item">
            <dt>{t('contact.phone')}</dt>
            <dd><a href={`tel:${siteConfig.phone.replace(/\s/g, '')}`}>{siteConfig.phone}</a></dd>
          </div>
          <div class="contact-info__item">
            <dt>{t('contact.email')}</dt>
            <dd><a href={`mailto:${siteConfig.email}`}>{siteConfig.email}</a></dd>
          </div>
          <div class="contact-info__item">
            <dt>{t('contact.address')}</dt>
            <dd>{siteConfig.address}</dd>
          </div>
        </dl>
      </aside>

      <!-- Formulario de contacto -->
      <!-- Usa Cloudflare Pages Smart Placement + Turnstile, o un servicio
           como Formspree / Web3Forms para procesar envíos estáticos.
           Reemplaza action con tu endpoint. -->
      <form
        class="contact-form"
        action="https://formspree.io/f/XXXXXXXX"
        method="POST"
        novalidate
      >
        <div class="form-field">
          <label for="name">{t('contact.form.name')} *</label>
          <input
            type="text"
            id="name"
            name="name"
            required
            autocomplete="name"
            placeholder={lang === 'ca' ? 'El teu nom' : 'Tu nombre'}
          />
        </div>

        <div class="form-field">
          <label for="email">{t('contact.form.email')} *</label>
          <input
            type="email"
            id="email"
            name="email"
            required
            autocomplete="email"
            placeholder={lang === 'ca' ? 'correu@exemple.com' : 'correo@ejemplo.com'}
          />
        </div>

        <div class="form-field">
          <label for="message">{t('contact.form.message')} *</label>
          <textarea
            id="message"
            name="message"
            rows="5"
            required
            placeholder={lang === 'ca' ? 'Escriu el teu missatge...' : 'Escribe tu mensaje...'}
          ></textarea>
        </div>

        <!-- Honeypot anti-spam -->
        <input type="text" name="_gotcha" style="display:none" tabindex="-1" autocomplete="off" />

        <button type="submit" class="btn btn--primary form-submit">
          {t('contact.form.send')}
        </button>
      </form>
    </div>
  </div>
</BaseLayout>

<style>
  .contact-layout {
    display: grid;
    gap: 3rem;
    grid-template-columns: 1fr;
  }

  @media (min-width: 700px) {
    .contact-layout {
      grid-template-columns: 1fr 2fr;
      align-items: start;
    }
  }

  .contact-info dl {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    margin: 0;
  }

  .contact-info__item dt {
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 0.2rem;
  }

  .contact-info__item dd {
    margin: 0;
    font-size: 1rem;
    color: var(--color-text);
    line-height: 1.5;
  }

  .contact-info__item a {
    color: var(--color-brand);
    text-decoration: none;
  }

  .contact-info__item a:hover {
    text-decoration: underline;
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .form-field {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .form-field label {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-text);
  }

  .form-field input,
  .form-field textarea {
    width: 100%;
    padding: 0.65rem 0.9rem;
    border: 1.5px solid var(--color-border);
    border-radius: 0.4rem;
    font-size: 1rem;
    font-family: inherit;
    color: var(--color-text);
    background-color: var(--color-surface);
    transition: border-color 0.15s;
  }

  .form-field input:focus,
  .form-field textarea:focus {
    outline: none;
    border-color: var(--color-brand);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--color-brand) 15%, transparent);
  }

  .form-field textarea {
    resize: vertical;
    min-height: 120px;
  }

  .form-submit {
    align-self: flex-start;
  }
</style>
