---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getEntry, render } from 'astro:content';
import { useTranslations } from '../../i18n/utils';
import type { Lang } from '../../i18n/ui';

const { courseId, lang } = Astro.props as { courseId: string; lang: Lang };
const course = await getEntry('cursos', courseId);
if (!course) {
  throw new Error(`Course not found: ${courseId}`);
}
const t = useTranslations(lang);
const { Content } = await render(course);

const levelLabels: Record<string, { es: string; ca: string }> = {
  iniciacion: { es: 'Iniciación', ca: 'Iniciació' },
  elemental:  { es: 'Elemental',  ca: 'Elemental' },
  medio:      { es: 'Medio',      ca: 'Mitjà' },
  avanzado:   { es: 'Avanzado',   ca: 'Avançat' },
  todos:      { es: 'Todos los niveles', ca: 'Tots els nivells' },
};

const levelLabel = levelLabels[course.data.level]?.[lang] ?? course.data.level;
const base = lang === 'es' ? '/es' : '';
---

<BaseLayout title={course.data.title} heroImage={course.data.image} {lang}>
  <article>
    {course.data.image && (
      <div class="course-hero">
        <img src={course.data.image} alt={course.data.title} class="img-cover" />
      </div>
    )}
    <div class="container section">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href={`${base}/`}>{t('nav.home')}</a>
        <span aria-hidden="true">›</span>
        <a href={`${base}/cursos/`}>{t('nav.courses')}</a>
        <span aria-hidden="true">›</span>
        <span aria-current="page">{course.data.title}</span>
      </nav>

      <header class="course-header">
        <span class="course-level">{levelLabel}</span>
        <h1>{course.data.title}</h1>
        <p class="course-short-desc">{course.data.shortDesc}</p>
      </header>

      <div class="prose">
        <Content />
      </div>

      <div class="course-cta">
        <a href={`${base}/${lang === 'ca' ? 'contacte' : 'contacto'}/`} class="btn btn--primary">
          {lang === 'ca' ? 'Inscriu-te' : 'Inscríbete'} →
        </a>
      </div>
    </div>
  </article>
</BaseLayout>

<style>
  .course-hero {
    height: clamp(220px, 35vw, 420px);
    overflow: hidden;
  }

  .course-hero img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .breadcrumb {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.85rem;
    color: var(--color-text-muted);
    margin-bottom: 2rem;
  }

  .breadcrumb a {
    color: var(--color-text-muted);
    text-decoration: none;
  }

  .breadcrumb a:hover {
    color: var(--color-brand);
  }

  .course-level {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-accent);
    display: block;
    margin-bottom: 0.5rem;
  }

  .course-header h1 {
    margin: 0 0 0.75rem;
  }

  .course-short-desc {
    font-size: 1.15rem;
    color: var(--color-text-muted);
    margin: 0 0 2.5rem;
    max-width: 60ch;
  }

  .course-cta {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--color-border);
  }
</style>
