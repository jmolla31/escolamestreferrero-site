---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import { useTranslations } from '../../i18n/utils';
import { getEntry, render } from 'astro:content';
import type { Lang } from '../../i18n/ui';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const bandajoveEntry = await getEntry('generic', `${lang}/banda-jove`);

const bandajoveDescription = bandajoveEntry?.data?.description || '';
const { Content } = bandajoveEntry ? await render(bandajoveEntry) : { Content: null };
---

<BaseLayout title={t('bandajove.title')} {lang}>
  <div class="container section">
    <SectionHeader title={t('bandajove.title')} />

    <div class="prose bandajove-content">
      {bandajoveDescription && (
        <p class="bandajove-intro">{bandajoveDescription}</p>
      )}
      {Content && <Content lang={lang} />}
    </div>
  </div>
</BaseLayout>

<style>
  .bandajove-content {
    max-width: 70ch;
  }
</style>
