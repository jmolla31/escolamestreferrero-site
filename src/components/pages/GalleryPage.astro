---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import { getCollection } from 'astro:content';
import { useTranslations } from '../../i18n/utils';
import type { Lang } from '../../i18n/ui';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const albums = await getCollection('galeria');
const sorted = albums.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<BaseLayout title={t('gallery.title')} {lang}>
  <div class="container section">
    <SectionHeader title={t('gallery.title')} />
    {sorted.length > 0
      ? sorted.map(album => (
        <section class="album">
          <h2 class="album__title">{album.data.title}</h2>
          {album.data.description && <p class="album__desc">{album.data.description}</p>}
          <div class="photo-grid">
            {album.data.photos.map(photo => (
              <figure class="photo-item">
                <img src={photo.src} alt={photo.alt} loading="lazy" />
              </figure>
            ))}
          </div>
        </section>
      ))
      : <p class="empty-state">{lang === 'ca' ? 'Galeria en construcció.' : 'Galería en construcción.'}</p>
    }
  </div>
</BaseLayout>

<style>
  .album {
    margin-bottom: 4rem;
  }

  .album__title {
    margin-bottom: 0.5rem;
  }

  .album__desc {
    color: var(--color-text-muted);
    margin-bottom: 1.5rem;
  }

  .photo-grid {
    display: grid;
    gap: 0.75rem;
    grid-template-columns: repeat(auto-fill, minmax(min(220px, 100%), 1fr));
  }

  .photo-item {
    margin: 0;
    border-radius: 0.5rem;
    overflow: hidden;
    aspect-ratio: 4 / 3;
    background-color: var(--color-surface-alt);
  }

  .photo-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .photo-item:hover img {
    transform: scale(1.04);
  }

  .empty-state {
    color: var(--color-text-muted);
    font-size: 1.1rem;
    padding: 3rem 0;
    text-align: center;
  }
</style>
