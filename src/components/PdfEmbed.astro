---
interface Props {
  src: string;
  title?: string;
  height?: string | number;
}

const { src, title = 'Document PDF', height = 700 } = Astro.props;
const heightPx = typeof height === 'number' ? `${height}px` : height;
---

<div class="pdf-embed">
  <iframe
    src={src}
    title={title}
    width="100%"
    style={`height:${heightPx}; border:none; border-radius:0.5rem;`}
  ></iframe>
  <a href={src} download class="pdf-embed__download btn btn--outline">
    ↓ Descarregar PDF
  </a>
</div>

<style>
  .pdf-embed {
    margin: 2rem 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .pdf-embed iframe {
    width: 100%;
    box-shadow: 0 2px 12px color-mix(in srgb, var(--color-text) 10%, transparent);
  }

  .pdf-embed__download {
    align-self: flex-start;
  }
</style>
