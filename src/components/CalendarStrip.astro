---
import type { Lang } from '../i18n/ui';
import { useTranslations } from '../i18n/utils';
import calendarHighlights from '../data/calendar-highlights.json';

interface Props {
  lang: Lang;
}

interface CalendarHighlightEntryInput {
  date?: string;
  startDate?: string;
  endDate?: string;
  color: string;
  label: Record<Lang, string>;
  description: Record<Lang, string>;
  post?: string;
}

interface CalendarEventSummary {
  eventKey: string;
  startDate: string;
  endDate: string;
  dateLabel: string;
  color: string;
  label: string;
  description: string;
  post?: string;
}

interface LocalizedEntry {
  dayKey: string;
  event: CalendarEventSummary;
}

interface MonthCell {
  key: string;
  dayNumber?: number;
  entry?: CalendarEventSummary;
  isPlaceholder: boolean;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const locale = lang === 'ca' ? 'ca-ES' : 'es-ES';
const emptyDetailsMessage = lang === 'ca'
  ? 'No hi ha activitats destacades en els mesos visibles.'
  : 'No hay actividades destacadas en los meses visibles.';

const parseIsoDate = (value: string) => {
  const [year, month, day] = value.split('-').map(Number);
  return new Date(year, month - 1, day);
};

const toIsoDate = (date: Date) => {
  const year = date.getFullYear();
  const month = String(date.getMonth() + 1).padStart(2, '0');
  const day = String(date.getDate()).padStart(2, '0');
  return `${year}-${month}-${day}`;
};

const eventDateFormatter = new Intl.DateTimeFormat(locale, { day: 'numeric', month: 'short' });

const formatEventDateLabel = (startIsoDate: string, endIsoDate: string) => {
  const startDate = parseIsoDate(startIsoDate);
  const endDate = parseIsoDate(endIsoDate);
  if (startIsoDate === endIsoDate) {
    return eventDateFormatter.format(startDate);
  }

  return `${eventDateFormatter.format(startDate)} - ${eventDateFormatter.format(endDate)}`;
};

const rawStartMonth = new Date(calendarHighlights.range.start.year, calendarHighlights.range.start.month - 1, 1);
const rawEndMonth = new Date(calendarHighlights.range.end.year, calendarHighlights.range.end.month - 1, 1);
const [startMonth, endMonth] = rawStartMonth <= rawEndMonth
  ? [rawStartMonth, rawEndMonth]
  : [rawEndMonth, rawStartMonth];

const calendarEntries = calendarHighlights.entries as CalendarHighlightEntryInput[];

const localizedEvents: CalendarEventSummary[] = calendarEntries.flatMap((entry, index) => {
  const rawStartDate = entry.startDate ?? entry.date;
  const rawEndDate = entry.endDate ?? entry.date;
  if (!rawStartDate || !rawEndDate) {
    return [];
  }

  const parsedStart = parseIsoDate(rawStartDate);
  const parsedEnd = parseIsoDate(rawEndDate);
  const [rangeStart, rangeEnd] = parsedStart <= parsedEnd
    ? [parsedStart, parsedEnd]
    : [parsedEnd, parsedStart];
  const normalizedStartDate = toIsoDate(rangeStart);
  const normalizedEndDate = toIsoDate(rangeEnd);

    return [{
      eventKey: `event-${index}`,
      startDate: normalizedStartDate,
      endDate: normalizedEndDate,
      dateLabel: formatEventDateLabel(normalizedStartDate, normalizedEndDate),
      color: entry.color,
      label: entry.label[lang],
      description: entry.description[lang],
      post: entry.post,
    }];
});

const localizedEntries: LocalizedEntry[] = localizedEvents.flatMap((event) => {
  const rangeStart = parseIsoDate(event.startDate);
  const rangeEnd = parseIsoDate(event.endDate);
  const expandedEntries: LocalizedEntry[] = [];

  for (
    let cursor = new Date(rangeStart.getFullYear(), rangeStart.getMonth(), rangeStart.getDate());
    cursor <= rangeEnd;
    cursor = new Date(cursor.getFullYear(), cursor.getMonth(), cursor.getDate() + 1)
  ) {
    expandedEntries.push({
      dayKey: toIsoDate(cursor),
      event,
    });
  }

  return expandedEntries;
});

const entriesByDate = new Map(localizedEntries.map((entry) => [entry.dayKey, entry.event]));
const monthFormatter = new Intl.DateTimeFormat(locale, { month: 'long', year: 'numeric' });
const weekdayFormatter = new Intl.DateTimeFormat(locale, { weekday: 'short' });
const weekdayLabels = Array.from({ length: 7 }, (_, index) => {
  const weekdayDate = new Date(2024, 0, index + 1);
  return weekdayFormatter.format(weekdayDate).replace('.', '').slice(0, 2).toUpperCase();
});

const months = [];

for (
  let cursor = new Date(startMonth.getFullYear(), startMonth.getMonth(), 1);
  cursor <= endMonth;
  cursor = new Date(cursor.getFullYear(), cursor.getMonth() + 1, 1)
) {
  const year = cursor.getFullYear();
  const monthIndex = cursor.getMonth();
  const firstWeekday = (new Date(year, monthIndex, 1).getDay() + 6) % 7;
  const daysInMonth = new Date(year, monthIndex + 1, 0).getDate();
  const cells: MonthCell[] = [];
  const monthEvents = new Map<string, CalendarEventSummary>();

  for (let offset = 0; offset < firstWeekday; offset += 1) {
    cells.push({
      key: `${year}-${monthIndex + 1}-placeholder-${offset}`,
      isPlaceholder: true,
    });
  }

  for (let day = 1; day <= daysInMonth; day += 1) {
    const isoDate = `${year}-${String(monthIndex + 1).padStart(2, '0')}-${String(day).padStart(2, '0')}`;
    const entry = entriesByDate.get(isoDate);
    if (entry && !monthEvents.has(entry.eventKey)) {
      monthEvents.set(entry.eventKey, entry);
    }

    cells.push({
      key: isoDate,
      dayNumber: day,
      entry,
      isPlaceholder: false,
    });
  }

  months.push({
    key: `${year}-${monthIndex + 1}`,
    title: monthFormatter.format(cursor),
    cells,
    events: Array.from(monthEvents.values()),
  });
}

const rangeLabel = `${monthFormatter.format(startMonth)} - ${monthFormatter.format(endMonth)}`;
---

<section
  class="calendar-strip"
  data-calendar-strip
  data-empty-details={emptyDetailsMessage}
  aria-label={lang === 'ca' ? 'Calendari d\'activitats' : 'Calendario de actividades'}
>
  <div class="calendar-strip__head">
    <div>
      <p class="calendar-strip__eyebrow">{lang === 'ca' ? 'Agenda visual' : 'Agenda visual'}</p>
      <h3 class="calendar-strip__title">{t('calendar.title')}</h3>
    </div>
    <p class="calendar-strip__range">{rangeLabel}</p>
  </div>

  <div class="calendar-strip__viewport">
    <button
      type="button"
      class="calendar-strip__nav"
      data-calendar-prev
      aria-label={lang === 'ca' ? 'Veure el mes anterior' : 'Ver el mes anterior'}
    >
      <span aria-hidden="true">&#8249;</span>
    </button>

    <div class="calendar-strip__months" data-calendar-months role="list">
      {months.map((month) => (
        <article class="calendar-strip__month-card" role="listitem" data-calendar-month-key={month.key} data-calendar-month-events={JSON.stringify(month.events)}>
          <h4 class="calendar-strip__month-title">{month.title}</h4>
          <div class="calendar-strip__weekdays" aria-hidden="true">
            {weekdayLabels.map((weekday) => (
              <span class="calendar-strip__weekday-head">{weekday}</span>
            ))}
          </div>
          <div class="calendar-strip__month-grid">
            {month.cells.map((cell) => {
              if (cell.isPlaceholder) {
                return <span class="calendar-strip__day calendar-strip__day--empty" aria-hidden="true"></span>;
              }

              if (cell.entry) {
                return (
                  <span
                    class="calendar-strip__day is-highlighted"
                    style={`--calendar-accent:${cell.entry.color}`}
                    title={`${cell.entry.label} (${cell.entry.dateLabel})`}
                  >
                    <span class="calendar-strip__number">{cell.dayNumber}</span>
                    <span class="calendar-strip__dot"></span>
                  </span>
                );
              }

              return (
                <span class="calendar-strip__day">
                  <span class="calendar-strip__number">{cell.dayNumber}</span>
                </span>
              );
            })}
          </div>
        </article>
      ))}
    </div>

    <button
      type="button"
      class="calendar-strip__nav"
      data-calendar-next
      aria-label={lang === 'ca' ? 'Veure el mes següent' : 'Ver el mes siguiente'}
    >
      <span aria-hidden="true">&#8250;</span>
    </button>
  </div>

  <div class="calendar-strip__details" data-calendar-details>
    <p class="calendar-strip__details-empty">{emptyDetailsMessage}</p>
  </div>
</section>

<script is:inline>
  (() => {
    const root = document.currentScript?.previousElementSibling;
    if (!(root instanceof HTMLElement)) return;

    const monthsEl = root.querySelector('[data-calendar-months]');
    const prevButton = root.querySelector('[data-calendar-prev]');
    const nextButton = root.querySelector('[data-calendar-next]');
    const detailsEl = root.querySelector('[data-calendar-details]');
    const emptyDetails = root.dataset.emptyDetails || '';
    const monthCards = Array.from(root.querySelectorAll('.calendar-strip__month-card'));
    const monthData = monthCards.map((card) => ({
      card,
      events: JSON.parse(card.dataset.calendarMonthEvents || '[]'),
    }));

    const renderVisibleEvents = () => {
      if (!(monthsEl instanceof HTMLElement) || !(detailsEl instanceof HTMLElement)) {
        return;
      }

      const viewportRect = monthsEl.getBoundingClientRect();
      const groups = new Map();

      monthData.forEach(({ card, events }) => {
        const rect = card.getBoundingClientRect();
        const isVisible = rect.right > viewportRect.left + 1 && rect.left < viewportRect.right - 1;
        if (!isVisible) {
          return;
        }

        events.forEach((event) => {
          let group = groups.get(event.color);
          if (!group) {
            group = {
              color: event.color,
              items: [],
              seenKeys: new Set(),
            };
            groups.set(event.color, group);
          }

          if (!group.seenKeys.has(event.eventKey)) {
            group.seenKeys.add(event.eventKey);
            group.items.push(event);
          }
        });
      });

      if (!groups.size) {
        detailsEl.innerHTML = `<p class="calendar-strip__details-empty">${emptyDetails}</p>`;
        return;
      }

      const groupsWrap = document.createElement('div');
      groupsWrap.className = 'calendar-strip__details-groups';

      groups.forEach((group) => {
        const groupEl = document.createElement('section');
        groupEl.className = 'calendar-strip__details-group';
        groupEl.style.setProperty('--calendar-accent', group.color);

        const list = document.createElement('ul');
        list.className = 'calendar-strip__details-list';

        group.items.forEach((event) => {
          const li = document.createElement('li');
          const item = event.post ? document.createElement('a') : document.createElement('div');
          item.className = 'calendar-strip__details-item';
          if (event.post) {
            item.setAttribute('href', event.post);
            item.style.textDecoration = 'none';
            item.style.color = 'inherit';
          }

          const date = document.createElement('span');
          date.className = 'calendar-strip__details-item-date';
          date.textContent = event.dateLabel;

          const separator = document.createElement('span');
          separator.className = 'calendar-strip__details-item-separator';
          separator.setAttribute('aria-hidden', 'true');

          const text = document.createElement('span');
          text.className = 'calendar-strip__details-item-text';
          text.textContent = event.description || event.label;

          item.append(date, separator, text);
          li.appendChild(item);
          list.appendChild(li);
        });

        groupEl.append(list);
        groupsWrap.appendChild(groupEl);
      });

      detailsEl.replaceChildren(groupsWrap);
    };

    const updateNavState = () => {
      if (!(monthsEl instanceof HTMLElement) || !(prevButton instanceof HTMLButtonElement) || !(nextButton instanceof HTMLButtonElement)) {
        return;
      }

      const hasOverflow = monthsEl.scrollWidth > monthsEl.clientWidth + 1;
      const maxScrollLeft = monthsEl.scrollWidth - monthsEl.clientWidth - 1;

      prevButton.disabled = !hasOverflow || monthsEl.scrollLeft <= 1;
      nextButton.disabled = !hasOverflow || monthsEl.scrollLeft >= maxScrollLeft;
    };

    const updateViewportState = () => {
      updateNavState();
      renderVisibleEvents();
    };

    const scrollByMonth = (direction) => {
      if (!(monthsEl instanceof HTMLElement)) return;

      const firstMonth = monthsEl.querySelector('.calendar-strip__month-card');
      if (!(firstMonth instanceof HTMLElement)) return;

      const styles = getComputedStyle(monthsEl);
      const gap = Number.parseFloat(styles.columnGap || styles.gap || '0');
      const amount = firstMonth.getBoundingClientRect().width + gap;

      monthsEl.scrollBy({
        left: direction * amount,
        behavior: 'smooth',
      });
    };

    if (monthsEl instanceof HTMLElement && prevButton instanceof HTMLButtonElement && nextButton instanceof HTMLButtonElement) {
      prevButton.addEventListener('click', () => scrollByMonth(-1));
      nextButton.addEventListener('click', () => scrollByMonth(1));
      monthsEl.addEventListener('scroll', updateViewportState, { passive: true });
      new ResizeObserver(updateViewportState).observe(monthsEl);

      const now = new Date();
      const currentMonthKey = `${now.getFullYear()}-${now.getMonth() + 1}`;
      const currentMonthCard = monthsEl.querySelector(`[data-calendar-month-key="${currentMonthKey}"]`);
      if (currentMonthCard) {
        currentMonthCard.scrollIntoView({ behavior: 'auto', block: 'nearest', inline: 'start' });
      }

      requestAnimationFrame(updateViewportState);
    }
  })();
</script>

<style>
  .calendar-strip {
    --calendar-month-gap: 1rem;
    --calendar-visible-months: 3;
    margin-top: 2.5rem;
    padding: 1.5rem;
    border-radius: 1.25rem;
    background: linear-gradient(135deg, rgba(14, 18, 53, 0.06), rgba(198, 179, 0, 0.08));
    border: 1px solid rgba(14, 18, 53, 0.1);
  }

  .calendar-strip__head {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .calendar-strip__eyebrow {
    margin: 0 0 0.25rem;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-accent);
  }

  .calendar-strip__title,
  .calendar-strip__range {
    margin: 0;
  }

  .calendar-strip__title {
    font-size: 1.35rem;
  }

  .calendar-strip__range {
    font-size: 0.92rem;
    color: var(--color-text-muted);
  }

  .calendar-strip__viewport {
    position: relative;
  }

  .calendar-strip__nav {
    width: 2.75rem;
    height: 2.75rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 2;
    border: 1px solid rgba(14, 18, 53, 0.12);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.9);
    color: var(--color-brand);
    font: inherit;
    font-size: 1.5rem;
    cursor: pointer;
    transition: background-color 0.15s ease, color 0.15s ease, opacity 0.15s ease;
  }

  .calendar-strip__nav[data-calendar-prev] {
    inset-inline-start: -1.375rem;
  }

  .calendar-strip__nav[data-calendar-next] {
    inset-inline-end: -1.375rem;
  }

  .calendar-strip__nav:hover:not(:disabled) {
    background: var(--color-brand);
    color: #fff;
  }

  .calendar-strip__nav:disabled {
    opacity: 0.35;
    cursor: default;
  }

  .calendar-strip__months {
    display: flex;
    gap: var(--calendar-month-gap);
    overflow-x: auto;
    padding-bottom: 0.75rem;
    scroll-snap-type: x proximity;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  .calendar-strip__months::-webkit-scrollbar {
    display: none;
  }

  .calendar-strip__month-card {
    flex: 0 0 calc((100% - (var(--calendar-visible-months) - 1) * var(--calendar-month-gap)) / var(--calendar-visible-months));
    min-width: 0;
    padding: 1rem;
    border-radius: 1rem;
    background: rgba(255, 255, 255, 0.72);
    border: 1px solid rgba(14, 18, 53, 0.08);
    scroll-snap-align: start;
  }

  .calendar-strip__month-title {
    margin: 0 0 0.85rem;
    font-size: 1rem;
    text-transform: capitalize;
  }

  .calendar-strip__weekdays,
  .calendar-strip__month-grid {
    display: grid;
    grid-template-columns: repeat(7, minmax(0, 1fr));
    gap: 0.35rem;
  }

  .calendar-strip__weekdays {
    margin-bottom: 0.35rem;
  }

  .calendar-strip__weekday-head {
    font-size: 0.7rem;
    text-align: center;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  .calendar-strip__day {
    display: grid;
    justify-items: center;
    align-content: center;
    min-height: 2.8rem;
    padding: 0.35rem 0.2rem;
    border: 1px solid rgba(14, 18, 53, 0.12);
    border-radius: 0.75rem;
    background: rgba(255, 255, 255, 0.72);
    color: var(--color-text);
    text-align: center;
  }

  .calendar-strip__day.is-highlighted {
    border-color: color-mix(in srgb, var(--calendar-accent) 55%, white);
    background: color-mix(in srgb, var(--calendar-accent) 10%, white);
  }

  .calendar-strip__day--empty {
    border: none;
    background: transparent;
    pointer-events: none;
  }

  .calendar-strip__number {
    font-size: 0.95rem;
    font-weight: 700;
  }

  .calendar-strip__dot {
    width: 0.42rem;
    height: 0.42rem;
    border-radius: 50%;
    background: var(--calendar-accent, transparent);
  }

  .calendar-strip__details {
    margin-top: 1rem;
    min-height: 4.75rem;
  }

  :global(.calendar-strip__details-groups) {
    display: grid;
    gap: 0.75rem;
  }

  :global(.calendar-strip__details-group) {
    padding: 0.9rem 1rem;
    border-radius: 1rem;
    background: color-mix(in srgb, var(--calendar-accent) 14%, white);
    border-inline-start: 4px solid var(--calendar-accent);
  }

  :global(.calendar-strip__details-list) {
    display: grid;
    gap: 0.55rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  :global(.calendar-strip__details-item) {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    flex-wrap: wrap;
    transition: opacity 0.15s ease;
  }

  :global(.calendar-strip__details-item[href]:hover) {
    opacity: 0.8;
  }

  :global(.calendar-strip__details-item-date),
  :global(.calendar-strip__details-item-text),
  :global(.calendar-strip__details-empty) {
    margin: 0;
  }

  :global(.calendar-strip__details-item-date) {
    font-weight: 700;
    color: var(--color-text-muted);
    white-space: nowrap;
  }

  :global(.calendar-strip__details-item-separator) {
    width: 0.85rem;
    height: 1px;
    background: color-mix(in srgb, var(--calendar-accent) 65%, transparent);
    transform: translateY(-0.12rem);
  }

  :global(.calendar-strip__details-item-text) {
    flex: 1 1 16rem;
  }

  :global(.calendar-strip__details-empty) {
    color: var(--color-text-muted);
  }

  @media (max-width: 720px) {
    .calendar-strip {
      --calendar-visible-months: 1;
    }

    .calendar-strip__head {
      align-items: start;
      flex-direction: column;
    }

    .calendar-strip__nav {
      width: 2.25rem;
      height: 2.25rem;
      font-size: 1.25rem;
    }

    .calendar-strip__nav[data-calendar-prev] {
      inset-inline-start: -1.125rem;
    }

    .calendar-strip__nav[data-calendar-next] {
      inset-inline-end: -1.125rem;
    }
  }

  @media (min-width: 721px) and (max-width: 1100px) {
    .calendar-strip {
      --calendar-visible-months: 2;
    }
  }
</style>